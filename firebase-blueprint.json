{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific data and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth." },
        "displayName": { "type": "string", "description": "User's full name." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile picture URL." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role in the system." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email"]
    },
    "CartItem": {
      "title": "Cart Item",
      "description": "Represents a product in a user's shopping cart.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "ID of the product." },
        "name": { "type": "string", "description": "Product name." },
        "price": { "type": "number", "description": "Price per unit." },
        "quantity": { "type": "integer", "description": "Number of units." },
        "size": { "type": "string", "description": "Selected size." },
        "image": { "type": "string", "format": "uri", "description": "Product image URL." },
        "addedAt": { "type": "string", "format": "date-time", "description": "When it was added to cart." }
      },
      "required": ["productId", "name", "price", "quantity"]
    },
    "WishlistItem": {
      "title": "Wishlist Item",
      "description": "Represents a product in a user's wishlist.",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "ID of the product." },
        "name": { "type": "string", "description": "Product name." },
        "price": { "type": "number", "description": "Price." },
        "image": { "type": "string", "format": "uri", "description": "Product image URL." },
        "addedAt": { "type": "string", "format": "date-time", "description": "When it was added to wishlist." }
      },
      "required": ["productId", "name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document."
    },
    "/users/{userId}/cart/{itemId}": {
      "schema": "CartItem",
      "description": "Items in the user's cart."
    },
    "/users/{userId}/wishlist/{itemId}": {
      "schema": "WishlistItem",
      "description": "Items in the user's wishlist."
    }
  }
}
